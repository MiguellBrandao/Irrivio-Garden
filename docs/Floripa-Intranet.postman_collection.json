    {
      "name": "Authentication",
      "item": [
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"miguellbwork@gmail.com\",\n  \"password\": \"Nodeapp2107.\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Returns accessToken, user and accessible companies. Each company includes branding, contact settings and the role in that company."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "  if (Array.isArray(json.companies) && json.companies[0]?.id) pm.collectionVariables.set('companyId', json.companies[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Cookie", "value": "{{refreshTokenCookie}}" }],
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Cookie", "value": "{{refreshTokenCookie}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me",
            "description": "Returns the authenticated user and accessible companies. Each company includes branding, contact settings and the role in that company."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (Array.isArray(json.companies) && json.companies[0]?.id) pm.collectionVariables.set('companyId', json.companies[0].id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
